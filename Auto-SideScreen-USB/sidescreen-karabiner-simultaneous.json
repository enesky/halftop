{
  "description": "SideScreen shortcuts: ctrl+option+s for USB, ctrl+option+s+w for Wireless",
  "manipulators": [
    {
      "type": "basic",
      "from": {
        "key_code": "s",
        "modifiers": {
          "mandatory": ["control", "option"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "shell_command": "/bin/bash '/Users/eky/Documents/MacOS Apps/Auto-SideScreen-USB/SideScreen-usb.sh'"
        }
      ]
    },
    {
      "type": "basic",
      "from": {
        "simultaneous": [
          { "key_code": "s" },
          { "key_code": "w" }
        ],
        "simultaneous_options": {
          "key_down_order": "strict",
          "key_up_order": "strict_inverse",
          "detect_key_down_uninterruptedly": true,
          "to_after_key_up": []
        },
        "modifiers": {
          "mandatory": ["control", "option"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "shell_command": "/bin/bash '/Users/eky/Documents/MacOS Apps/Auto-SideScreen-USB/SideScreen-wireless.sh'"
        }
      ]
    }
  ]
}
